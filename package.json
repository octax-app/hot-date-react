{
  "name": "hot-date-react",
  "version": "1.1.2",
  "description": "React wrapper for the hot-date natural language date input web component.",
  "type": "module",
  "main": "./dist/hot-date.js",
  "module": "./dist/hot-date.js",
  "types": "./dist/hot-date.d.ts",
  "exports": {
    ".": {
      "types": "./dist/hot-date.d.ts",
      "import": "./dist/hot-date.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/hot-date-react.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/hot-date.js",
    "./dist/hot-date-react.js"
  ],
  "keywords": [
    "date-picker",
    "date-input",
    "web-component",
    "custom-element",
    "react"
  ],
  "author": "Scott Tolinski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stolinski/hot-date.git"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "node --import tsx bench/parser.bench.ts",
    "coverage:variations": "node --import tsx scripts/variation-coverage.ts",
    "coverage:variations:strict": "node --import tsx scripts/variation-coverage.ts --strict",
    "prepublishOnly": "npm test && npm run build"
  },
  "devDependencies": {
    "@js-temporal/polyfill": "^0.4.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "tailwindcss": "^4.0.0",
    "tinybench": "^2.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
