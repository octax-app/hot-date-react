{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx"
  },
  "include": [
    "src/hot-date.ts",
    "src/lib/**/*.ts",
    "src/react/**/*.ts",
    "src/react/**/*.tsx"
  ],
  "exclude": ["tests", "bench", "scripts"]
}
